FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# ta_service 的log level
TA_SERVICE_LOG_LEVEL=INFO

# 报告落盘根目录（各 agent 原始输出按子目录分阶段保存）
TA_SERVICE_REPORTS_DIR=./reports

# 活跃分析任务的超时时长（秒）：updatedAt 超过此时间的活跃任务视为僵尸，允许用户重新发起分析
TA_SERVICE_ANALYSIS_TASK_TTL_SECONDS=180


# 调试开关：true 时 create_task 跳过 worker 启动，直接将任务和会话置为 report_ready
TA_SERVICE_DEBUG_SKIP_ANALYSIS=false

# 本地开发时监听所有网卡，方便手机局域网调试（生产环境不使用此文件）
TA_SERVICE_HOST=0.0.0.0

# 允许的跨域来源（本地开发含局域网 IP，方便手机调试）
TA_SERVICE_CORS_ORIGINS=http://127.0.0.1:3100,http://localhost:3100,http://10.0.26.50:3100

