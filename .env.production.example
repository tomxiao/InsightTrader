# ── ta_service 核心配置 ────────────────────────────────────────────────────────
TA_SERVICE_ENV=production
TA_SERVICE_HOST=0.0.0.0
TA_SERVICE_PORT=8100

# ── 数据库（Docker 内网服务名）────────────────────────────────────────────────
TA_SERVICE_MONGO_URI=mongodb://mongo:27017
TA_SERVICE_MONGO_DB=ta_service
TA_SERVICE_REDIS_URL=redis://redis:6379/0

# ── 安全 ──────────────────────────────────────────────────────────────────────
# 生产环境必须修改为随机强字符串（openssl rand -hex 32）
TA_SERVICE_AUTH_TOKEN_PREFIX=REPLACE_WITH_RANDOM_SECRET

# ── 跨域（允许前端域名）──────────────────────────────────────────────────────
TA_SERVICE_CORS_ORIGINS=http://93901.pro,http://www.93901.pro,http://93901.pro/api

# ── 任务配置 ──────────────────────────────────────────────────────────────────
TA_SERVICE_ANALYSIS_TASK_TTL_SECONDS=180

# ── LLM 提供商（填写实际使用的 Key）─────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ── 数据源 ────────────────────────────────────────────────────────────────────
TUSHARE_TOKEN=
FINNHUB_TOKEN=
